# Copy to .env and fill in values. Never commit .env.
#
# =============================================================================
# AWS — Option A: SSO profile
# =============================================================================
# AWS_PROFILE=risk-fraud
# AWS_DEFAULT_REGION=eu-west-1
#
# =============================================================================
# AWS — Option B: temporary credentials (IAM Identity Center → Access keys)
# =============================================================================
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# AWS_DEFAULT_REGION=eu-west-1
#
# Zenka Kenya S3
# ID fronts: s3://sf-zenka-ke-prod-media-svc/id-doc-front/
# Selfies:   s3://sf-zenka-ke-prod-media-svc/selfie/
AWS_S3_BUCKET=sf-zenka-ke-prod-media-svc
#
# =============================================================================
# Zenka Kenya database (postgres2)
# =============================================================================
# Recommended: separate fields (password can contain @, ~, etc. — no encoding needed)
ZENKA_KE_DB_HOST=
ZENKA_KE_DB_PORT=5432
ZENKA_KE_DB_NAME=
ZENKA_KE_DB_USER=
ZENKA_KE_DB_PASSWORD=
#
# Alternative: full URL (password must be URL-encoded: @ → %40, ~ → %7E)
# ZENKA_KE_DATABASE_URL=postgresql://user:pass%40word@host:5432/dbname
#
# =============================================================================
# PH (optional — separate product)
# =============================================================================
# AWS_S3_BUCKET_PH=
# AWS_S3_PREFIX=feature_store/
# DATABASE_URL=postgresql://user:password@host:5432/database
# ERP_SCHEMA=erp_finbro_ph
